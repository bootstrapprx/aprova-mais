# .env.local

# disabled next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# Database (postgres via docker compose)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/aprova_mais"
# Se 5433 estiver ocupada, ajuste para a porta livre em docker-compose.yml

# Supabase Auth (client-side, via host)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:9999
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBsYWNlaG9sZGVyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3MDAwMDAwMDAsImV4cCI6MjAzMDAwMDAwMH0.abc123

# Supabase Auth (server-side, rede interna Docker)
SUPABASE_URL=http://auth:9999
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBsYWNlaG9sZGVyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3MDAwMDAwMDAsImV4cCI6MjAzMDAwMDAwMH0.abc123

# Admin (IDs dos usuários Supabase separados por ", ")
SUPABASE_ADMIN_IDS=""

# Stripe (desativado - deixar valores placeholder)
STRIPE_API_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Public app url
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mobile (Capacitor) — URL do servidor para o app mobile
# Se definido, o Capacitor carrega o app desta URL em vez do bundle local
# CAPACITOR_SERVER_URL=https://aprovamais.com.br


{
  "name": "aprova-mais",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --check --ignore-path .gitignore .",
    "format:fix": "prettier --write --ignore-path .gitignore .",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:prod": "tsx ./scripts/prod.ts",
    "mobile:init": "npx cap init aprova-mais com.aprova.mais && npx cap add android && npx cap add ios",
    "mobile:sync": "npx cap sync",
    "mobile:copy": "npx cap copy",
    "mobile:open:android": "npx cap open android",
    "mobile:open:ios": "npx cap open ios",
    "mobile:build:android": "bash scripts/mobile-build-android.sh",
    "mobile:build:ios": "bash scripts/mobile-build-ios.sh",
    "mobile:dev:android": "CAPACITOR_SERVER_URL=http://localhost:3000 npx cap run android",
    "mobile:dev:ios": "CAPACITOR_SERVER_URL=http://localhost:3000 npx cap run ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "@vercel/config": "^0.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.20.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "ra-data-simple-rest": "^5.15.0",
    "ra-i18n-polyglot": "^4.0.0",
    "ra-language-portuguese": "^1.6.0",
    "react": "^19.2.7",
    "react-admin": "^5.15.1",
    "react-circular-progressbar": "^2.2.0",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.7",
    "react-use": "^17.6.1",
    "sonner": "^2.0.7",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "pg": "^8.22.0",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "^6"
  },
  "author": {
    "name": "bootstrapprx",
    "url": "https://github.com/bootstrapprx"
  },
  "description": "Plataforma de estudos para concursos públicos com simulados, questões e acompanhamento de desempenho.",
  "keywords": [
    "concursos",
    "estudos",
    "simulados",
    "nextjs",
    "react",
    "shadcn",
    "postgresql",
    "drizzle",
    "tailwindcss",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bootstrapprx/aprova-mais.git"
  },
  "homepage": "https://github.com/bootstrapprx/aprova-mais#readme",
  "bugs": {
    "url": "https://github.com/bootstrapprx/aprova-mais/issues"
  },
  "funding": []
}
